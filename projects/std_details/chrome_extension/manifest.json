{
  "manifest_version": 3,
  "name": "Student Details Scraper",
  "version": "1.0",
  "description": "Scrapes student details from pulse.itvedant.com automatically across pages.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "*://pulse.itvedant.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://pulse.itvedant.com/student/active-learners*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
